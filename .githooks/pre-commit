#!/bin/sh
echo "Running Pre-Commit Checks (GangNiaga OS)..."

# Basic Secret Scanning
if git diff --cached -G"(API_KEY|PASSWORD|SECRET)=" --name-only | grep -q "."; then
  echo "Error: Potential secrets found in staged files."
  echo "Please review your code or use git commit --no-verify if it's a false positive."
  exit 1
fi

# Run Linter if Node environment is ready
if [ -f "package.json" ] && [ -d "node_modules" ]; then
  echo "Running Linter..."
  npm run lint || exit 1
fi

echo "Pre-commit checks passed. Proceeding with commit."
exit 0
